datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id        String   @id @default(uuid())
  name      String   @unique
  users     User[]
  logs      SystemLog[]
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   
  role      String   
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model SystemLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  action    String
  status    String   
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model SystemConfig {
  id               String  @id @default("global_config")
  systemLockActive Boolean @default(false)
}